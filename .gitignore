node_modules/
*.log
.DS_Store
.env
models/*
!models/.gitkeep
scripts/bin/
scripts/whisper.cpp/
dist/

# Personal persona / memory / session — user-specific, not committed.
# Defaults live in persona.default.md and memory.default.md.
persona.md
memory.md
.iris/

# Personal avatar images dropped into the portrait renderer path.
# PortraitStage supports any PNG/JPG, but the actual file is a user
# choice (often an AI-generated still of their character) so we
# keep it out of git.
web/public/avatars/*
!web/public/avatars/.gitkeep
